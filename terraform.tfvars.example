traefik_hub_tag       = "v3.20.0"
traefik_chart_version = "40.0.0-ea.1"

domain = "demo.traefik.localhost"

traefik_hub_token     = "YOUR_TRAEFIK_HUB_TOKEN" 
enable_offline_mode = false

# Optional: per-cluster license overrides
# transit_hub_token      = "TRANSIT_TOKEN"
# app_workload_hub_token = "APP_WORKLOAD_TOKEN"
# ai_workload_hub_token  = "AI_WORKLOAD_TOKEN"

# Optional: use a locally-built traefik-hub image instead of upstream
# (run `make build-hub` first to populate localhost:5001/traefik/traefik-hub:dev).
# local_traefik_hub = true

# Optional: ai-gateway endpoint API keys
# openai_api_key    = "sk-..."
# gemini_api_key    = "AIza..."
# anthropic_api_key = "sk-ant-..."